# Porta do servidor
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# JWT - OBRIGATÓRIO trocar em produção (use uma string aleatória de 64+ caracteres)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=mude_esta_chave_em_producao_2024

# Origem CORS permitida (use "*" em dev, domínio específico em produção)
CORS_ORIGIN=*
